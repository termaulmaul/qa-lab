meta {
  name: Health Check
  type: http
  seq: 1
}

get {
  url: http://localhost:8000/health
  body: none
  auth: none
}

tests {
  test("health status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("market status exists", function() {
    const body = res.getBody();
    expect(["OPEN", "HALTED", "CLOSED"]).to.include(body.marketStatus);
  });
}
